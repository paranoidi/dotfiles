[include]
    path = .gitconfig.local
[core]
   pager = delta
	hooksPath = /home/paranoidi/.git-hooks
[interactive]
   diffFilter = delta --color-only
[delta]
   navigate = true  # use n and N to move between diff sections
   dark = true      # or light = true, or omit for auto-detection
[diff]
    colorMoved = default
[merge]
    tool = vim
    conflictstyle = diff3
[color]
    ui = true
[pull]
    rebase = true
[push]
    default = current
[init]
    defaultBranch = main
[log]
    date = iso
[apply]
    # remove trailing whitespaces
    whitespace = fix
[alias]
    ci = commit
    st = status
    lc = log ORIG_HEAD.. --stat --no-merges
    co = checkout
    lgo = log --decorate --stat --graph
    inc = "!git remote update -p; git log ..@{u}"
    out = log @{u}..
    lg = log --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
    fixup = "!f() { TARGET=$(git rev-parse $1); shift; git commit --fixup=$TARGET \"$@\" && GIT_SEQUENCE_EDITOR=true git rebase -i --autostash --autosquash $TARGET^; }; f"
	stash-staged = stash --staged
	stash-unstaged = stash --keep-index
[credential "https://github.com"]
    helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper = !/usr/bin/gh auth git-credential
[mergetool]
    prompt = false
[commit]
    verbose = true
[rebase]
    autoStash = true
	updateRefs = true
