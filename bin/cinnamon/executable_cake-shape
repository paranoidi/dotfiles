#!/bin/bash
# cake-shape — apply cake qdisc with bandwidth shaping on a selected interface
#
# Usage: cake-shape [<interface> <bandwidth>] [--persist]
#   Interactive mode (default): prompts for interface and bandwidth
#   Non-interactive:  cake-shape eno2 50mbps
#   Persistent:       cake-shape eno2 18MiB --persist   (non-interactive, save)
#                     cake-shape --remove-persistence   (clean up)
#
# Bandwidth formats:
#   18MiB       -> 18 mebibytes/sec (converts to bits for tc)
#   100mbit     -> 100 megabits/sec
#   50mbps      -> 50 megabytes/sec
#   150mbit     -> 150 megabits/sec
#   1gbps       -> 1 gigabyte/sec
#   20kib       -> 20 kibibytes/sec

set -euo pipefail

DISPATCHER_DIR="/etc/NetworkManager/dispatcher.d"

bail() { echo "error: $*" >&2; exit 1; }

# ─── Bandwidth parser ─────────────────────────────────────────────────────────
parse_bandwidth() {
    local raw="$1"
    local num unit

    # Extract leading number (int or float)
    num=$(echo "$raw" | sed -E 's/^([0-9]+(\.[0-9]+)?).*/\1/')
    [[ -n "$num" ]] || bail "could not parse a number from '$raw'"

    # Extract trailing unit, lowercased
    unit=$(echo "$raw" | sed -E 's/^[0-9]+(\.[0-9]+)?//' | tr '[:upper:]' '[:lower:]')

    case "$unit" in
        mib|mebibytes|me|mi|"")
            # Default: no unit → mebibytes/sec
            python3 -c "print(f'{int($num * 1024 * 1024 * 8)}bit')"
            ;;
        mb|mbps|mbytes|mbyte|mbs)
            echo "${num}mbps"
            ;;
        mbit|m)
            echo "${num}mbit"
            ;;
        gb|gbps|gbytes|gbyte|gbs)
            echo "${num}gbps"
            ;;
        gib|gibibytes|gi)
            python3 -c "print(f'{int($num * 1024 * 1024 * 1024 * 8)}bit')"
            ;;
        kbit|k)
            echo "${num}kbit"
            ;;
        kb|kbps|kbytes|kbs)
            echo "${num}kbps"
            ;;
        kib|kibibytes|ki)
            python3 -c "print(f'{int($num * 1024)}kbit')"
            ;;
        *)
            bail "unknown unit '$unit' — use mbit, mbps, MiB, kib, etc."
            ;;
    esac
}

# ─── Human-friendly bandwidth display ─────────────────────────────────────────
human_bandwidth() {
    local raw="$1"
    local num unit
    num=$(echo "$raw" | sed -E 's/^([0-9]+(\.[0-9]+)?).*/\1/')
    unit=$(echo "$raw" | sed -E 's/^[0-9]+(\.[0-9]+)?//' | tr '[:upper:]' '[:lower:]')

    case "$unit" in
        mib|mebibytes|me|mi|"")    echo "$num MiB/s" ;;
        mb|mbps|mbytes|mbyte|mbs)  echo "$num MB/s"  ;;
        mbit|m)                    echo "$num Mbit/s";;
        gb|gbps|gbytes|gbyte|gbs)  echo "$num GB/s"  ;;
        gib|gibibytes|gi)          echo "$num GiB/s" ;;
        kbit|k)                    echo "$num Kbit/s";;
        kb|kbps|kbytes|kbs)        echo "$num KB/s"  ;;
        kib|kibibytes|ki)          echo "$num KiB/s" ;;
        *)                         echo "$raw"        ;;
    esac
}

# ─── Interface listing with metadata ──────────────────────────────────────────
list_interfaces() {
    ip -o link show | while read _ iface rest; do
        # strip trailing colon from the name field and @peer suffix (e.g. vethX@if2)
        iface="${iface%:}"
        iface="${iface%@*}"
        [[ "$iface" = "lo" ]] && continue

        # extract state from the line we already fetched
        state=$(echo "$rest" | sed -n 's/.* state \([[:alpha:]]*\) .*/\1/p')
        state=${state:-unknown}

        ip4=$(ip -4 addr show dev "$iface" 2>/dev/null | awk '/inet /{print $2}' | head -1)
        ip4=${ip4:-"-"}
        speed=$(cat "/sys/class/net/$iface/speed" 2>/dev/null || echo "?")
        echo "$iface  $state  $ip4  ${speed}Mbps"
    done
}

# ─── Yes/no prompt helper ─────────────────────────────────────────────────────
confirm() {
    local prompt="$1" default="${2:-y}"
    if command -v gum &>/dev/null; then
        gum confirm "$prompt" && return 0 || return 1
    else
        local yn
        read -rp "$prompt [Y/n] " yn
        yn=${yn:-y}
        [[ "$yn" =~ ^[Yy]$ ]]
    fi
}

# ─── Persistence helpers ──────────────────────────────────────────────────────
persist_script_path() {
    local iface="$1"
    echo "$DISPATCHER_DIR/50-cake-shape-$iface"
}

has_persistence() {
    local iface="$1"
    [[ -f "$(persist_script_path "$iface")" ]]
}

remove_persistence() {
    local iface="$1"
    local path
    path=$(persist_script_path "$iface")
    if [[ -f "$path" ]]; then
        echo "  removing $path"
        sudo rm -f "$path"
        echo "  done — persistence removed for $iface"
    else
        echo "  no persistence script found for $iface"
    fi
}

apply_persistence() {
    local iface="$1" bandwidth_raw="$2" bandwidth="$3"
    local path
    path=$(persist_script_path "$iface")

    local content
    content="#!/bin/bash
# Auto-generated by cake-shape — $(date +%Y-%m-%d)
# bandwidth: $(human_bandwidth "$bandwidth_raw") ($bandwidth)
IFACE=\"\$1\"
ACTION=\"\$2\"
[ \"\$IFACE\" = \"$iface\" ] || exit 0
[ \"\$ACTION\" = \"up\" ] || exit 0
tc qdisc replace dev \"\$IFACE\" root cake bandwidth $bandwidth
"

    echo "$content" | sudo tee "$path" >/dev/null
    sudo chmod 755 "$path"
    echo "  written: $path"
}

# ─── List all persistent configs ──────────────────────────────────────────────
list_persistence() {
    if compgen -G "$DISPATCHER_DIR/50-cake-shape-*" &>/dev/null; then
        echo "Current persistent cake-shape configs:"
        for f in "$DISPATCHER_DIR"/50-cake-shape-*; do
            iface="${f##*50-cake-shape-}"
            bw=$(grep -m1 'bandwidth:' "$f" | sed 's/.*bandwidth: //' | sed 's/ (.*//')
            echo "  $iface  →  $bw"
        done
    else
        echo "No persistent cake-shape configs found."
    fi
}

# ─── Non-interactive: --remove-persistence ────────────────────────────────────
if [[ $# -ge 1 && "$1" == "--remove-persistence" ]]; then
    list_persistence
    echo ""
    if command -v gum &>/dev/null; then
        IFACE=$(list_interfaces | gum filter --placeholder "Interface to remove persistence for..." --header "Interface  State  IP  Speed" | awk '{print $1}')
    else
        read -rp "Interface to remove persistence for: " IFACE
    fi
    [[ -n "$IFACE" ]] || exit 0
    remove_persistence "$IFACE"
    exit 0
fi

# ─── Non-interactive mode ─────────────────────────────────────────────────────
if [[ $# -ge 2 ]]; then
    IFACE="$1"
    BANDWIDTH_RAW="$2"
    PERSIST=false
    # Check for --persist flag (any position)
    for arg in "$@"; do
        if [[ "$arg" == "--persist" ]]; then
            PERSIST=true
        fi
    done

    BANDWIDTH=$(parse_bandwidth "$BANDWIDTH_RAW")
    echo "→ Interface: $IFACE"
    echo "→ Bandwidth: $(human_bandwidth "$BANDWIDTH_RAW") ($BANDWIDTH)"
    echo ""
    sudo tc qdisc replace dev "$IFACE" root cake bandwidth "$BANDWIDTH"
    echo ""
    echo "done — current qdisc on $IFACE:"
    tc qdisc show dev "$IFACE" | head -5

    if [[ "$PERSIST" == true ]]; then
        echo ""
        echo "making persistent..."
        apply_persistence "$IFACE" "$BANDWIDTH_RAW" "$BANDWIDTH"
    fi

    exit 0
fi

# ─── Interactive mode ─────────────────────────────────────────────────────────

echo "=== cake-shape — bandwidth shaping with cake qdisc ==="
echo ""

# ── Step 1: pick interface ──
echo "Available interfaces:"

IFACE_LIST=$(list_interfaces)

if command -v gum &>/dev/null; then
    IFACE=$(echo "$IFACE_LIST" | gum filter --placeholder "Pick an interface to shape..." --header "Interface  State  IP  Speed" | awk '{print $1}')
elif command -v fzf &>/dev/null; then
    echo "$IFACE_LIST" | head -1 | awk '{print "  "$0}'
    IFACE=$(echo "$IFACE_LIST" | fzf --header-lines=0 --prompt="Interface > " | awk '{print $1}')
else
    echo "$IFACE_LIST"
    echo ""
    read -rp "Enter interface name: " IFACE
fi

[[ -n "$IFACE" ]] || bail "no interface selected"
ip link show "$IFACE" &>/dev/null || bail "interface '$IFACE' does not exist"

# ── Step 2: enter bandwidth ──
echo ""
if command -v gum &>/dev/null; then
    BANDWIDTH_RAW=$(gum input --placeholder "18MiB" --header "Enter bandwidth (e.g. 18MiB, 100mbit, 50mbps)")
elif command -v fzf &>/dev/null; then
    read -rp "Bandwidth (e.g. 18MiB, 100mbit, 50mbps): " BANDWIDTH_RAW
else
    read -rp "Bandwidth (e.g. 18MiB, 100mbit, 50mbps): " BANDWIDTH_RAW
fi

BANDWIDTH_RAW=${BANDWIDTH_RAW:-18MiB}
BANDWIDTH=$(parse_bandwidth "$BANDWIDTH_RAW")

# ── Step 3: show before & apply ──
echo "  Interface: $IFACE"
echo "  Bandwidth: $(human_bandwidth "$BANDWIDTH_RAW")"
echo "  tc rate:   $BANDWIDTH"
echo ""

echo "Current qdisc on $IFACE:"
tc qdisc show dev "$IFACE" | head -5
echo ""

confirm "Apply cake qdisc?" || bail "cancelled"

sudo tc qdisc replace dev "$IFACE" root cake bandwidth "$BANDWIDTH"

echo ""
echo "done — new qdisc on $IFACE:"
tc qdisc show dev "$IFACE" | head -5
echo ""

# ── Step 4: offer persistence ──
if has_persistence "$IFACE"; then
    echo "Persistent config already exists for $IFACE:"
    grep -m1 'bandwidth:' "$(persist_script_path "$IFACE")" | sed 's/.*bandwidth: /  /'
    if confirm "Update persistent config?"; then
        apply_persistence "$IFACE" "$BANDWIDTH_RAW" "$BANDWIDTH"
    fi
    if confirm "Also remove persistence?"; then
        remove_persistence "$IFACE"
    fi
else
    if confirm "Make this persistent across reboots (NetworkManager dispatcher)?"; then
        apply_persistence "$IFACE" "$BANDWIDTH_RAW" "$BANDWIDTH"
    fi
fi

echo "All done."
