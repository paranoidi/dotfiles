#!/usr/bin/env bash
# tmux-window-status cmd title path
# Outputs: "<icon> <info>" for one window status entry.
# Arguments passed from .tmux.conf:
#   $1  pane_current_command
#   $2  pane_title
#   $3  pane_current_path

cmd="$1"
title="$2"
path="$3"

# normalize aliases so icon + title-strip logic can use one canonical name
# original_cmd is kept for suffix stripping (e.g. "- VIM", "- NVIM")
original_cmd="$cmd"
case "$cmd" in batcat) cmd=bat ;; vim|nvim) cmd=vi ;; esac

# --- icon + use_title flag ---
case "$cmd" in
    fish)                   icon="🐟" ;;
    python3|python)         icon="🐍" ;;
    find|ag|rg)             icon="🔍" ;;
    sleep)                  icon="🕓" ;;
    docker)                 icon="📦" ;;
    sudo)                   icon="💥" ;;
    cp|rsync|dd)            icon="💾" ;;
    ssh|scp)                icon="📡" ;;
    curl|wget|gh)           icon="🌐" ;;
    eza)                    icon="🗂️" ;;
    nvim|vi)                icon="✏️"; use_title=1 ;;
    bat|less)               icon="📃"; use_title=1 ;;
    man)                    icon="📖"; use_title=1 ;;
    *)                      icon="$cmd" ;;
esac

# --- info ---
if [[ -n "$use_title" ]]; then
    info="${title#$cmd }"        # strip leading "cmd " if present
    info="${info% - ${original_cmd^^}}"  # strip trailing " - CMD" suffix (e.g. nvim → " - NVIM", vim → " - VIM")
    info="${info% [~\/]*}"       # strip trailing path-like word
else
    display="${path/$HOME/\~}"
    if [[ "$display" != */* ]]; then
        # path is $HOME itself or a single-component path like /tmp
        info="$display"
    else
        base="${display##*/}"
        parent_path="${display%/*}"
        parent="${parent_path##*/}"
        if [[ -z "$parent" ]]; then
            candidate="/$base"         # e.g. /tmp
        else
            candidate="$parent/$base"  # e.g. ~/bin or projects/myapp
        fi
        if [[ ${#candidate} -lt 20 ]]; then
            info="$candidate"
        else
            info="$base"
        fi
    fi
fi

printf '%s %s' "$icon" "$info"
