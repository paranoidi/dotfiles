#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "inquirerpy",
#     "rich",
# ]
# ///
"""Escalating process kill: TERM → INT → HUP → KILL

More graceful than kill -9 — gives the process a chance to clean up.

Usage:
    murder <name>     Kill by process name
    murder 123        Kill by PID
    murder :3000      Kill by port
    murder ruby :3000 Multiple arguments
"""

import os
import signal
import subprocess
import sys
import time

from InquirerPy import inquirer
from rich.console import Console

SIGNALS = [
    (signal.SIGTERM, 2.5),
    (signal.SIGINT, 2.5),
    (signal.SIGHUP, 2.5),
    (signal.SIGKILL, 0),
]

MY_PID = os.getpid()
console = Console()
err_console = Console(stderr=True)


def is_running(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def get_command(pid: int) -> str:
    try:
        result = subprocess.run(
            ["ps", "-p", str(pid), "-o", "command="],
            capture_output=True,
            text=True,
        )
        return result.stdout.strip()
    except Exception:
        return "<unknown>"


def confirm(prompt: str) -> bool:
    return bool(inquirer.confirm(message=prompt, default=False).execute())


def spin_sleep(title: str, seconds: float) -> None:
    with console.status(title, spinner="dots"):
        time.sleep(seconds)


def murder_pid(pid: int) -> None:
    for sig, wait in SIGNALS:
        if not is_running(pid):
            break
        console.print(f"→ Sending {sig.name} to {pid}...", style="magenta")
        try:
            os.kill(pid, sig)
        except OSError:
            break
        if wait > 0 and is_running(pid):
            spin_sleep(f"Waiting for {pid} to exit after {sig.name}...", wait)

    if is_running(pid):
        console.print(f"⚠ {pid} may still be running.", style="bold red")
    else:
        console.print(f"✓ {pid} terminated.", style="bold green")


def select_pids(processes: list[tuple[int, str]], title: str) -> list[int]:
    if not processes:
        return []

    choices = [
        {"name": f"{pid}\t{cmd}", "value": pid}
        for pid, cmd in processes
    ]

    console.print(title, style="bold yellow")
    if len(choices) == 1:
        pid, cmd = processes[0]
        return [pid] if confirm(f"Murder {cmd} (pid {pid})?") else []

    return list(inquirer.checkbox(
        message="Select processes to murder",
        choices=choices,
        instruction="(space to select, enter to confirm)",
    ).execute())


def murder_selected(processes: list[tuple[int, str]], title: str) -> None:
    pids = select_pids(processes, title)
    if not pids:
        return

    console.print(f"⚠ About to terminate {len(pids)} process(es)", style="bold red")
    if not confirm("Proceed?"):
        return

    for pid in pids:
        murder_pid(pid)


def unique_processes(pids: list[int]) -> list[tuple[int, str]]:
    seen: set[int] = set()
    processes: list[tuple[int, str]] = []
    for pid in pids:
        if pid == MY_PID or pid in seen:
            continue
        seen.add(pid)
        processes.append((pid, get_command(pid)))
    return processes


def murder_by_pid(pid: int) -> None:
    if not is_running(pid):
        err_console.print(f"No process with PID {pid}", style="red")
        return
    murder_selected([(pid, get_command(pid))], f"Process {pid}")


def murder_by_port(port_arg: str) -> None:
    port = port_arg[1:]
    result = subprocess.run(
        ["lsof", "-nP", f"-iTCP:{port}", "-sTCP:LISTEN"],
        capture_output=True,
        text=True,
    )
    if not result.stdout.strip():
        console.print(f"No processes listening on port {port_arg}")
        return

    pids: list[int] = []
    for line in result.stdout.splitlines()[1:]:
        parts = line.split(None, 2)
        if len(parts) >= 2:
            pids.append(int(parts[1]))

    murder_selected(unique_processes(pids), f"Processes listening on {port_arg}")


def murder_by_name(name: str) -> None:
    result = subprocess.run(
        ["pgrep", "-fi", name],
        capture_output=True,
        text=True,
    )
    processes = unique_processes([int(p) for p in result.stdout.split()])
    if not processes:
        console.print(f"No processes matching '{name}'")
        return

    murder_selected(processes, f"Processes matching '{name}'")


def is_int(s: str) -> bool:
    try:
        int(s)
        return True
    except ValueError:
        return False


def murder(arg: str) -> None:
    if is_int(arg):
        murder_by_pid(int(arg))
    elif arg.startswith(":") and is_int(arg[1:]):
        murder_by_port(arg)
    else:
        murder_by_name(arg)


def main() -> None:
    if len(sys.argv) < 2:
        err_console.print("usage:", style="bold")
        err_console.print("  murder 123     kill by pid")
        err_console.print("  murder ruby    kill by process name")
        err_console.print("  murder :3000   kill by port")
        sys.exit(1)

    for arg in sys.argv[1:]:
        murder(arg)


if __name__ == "__main__":
    main()
